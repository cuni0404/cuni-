rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{allPaths=**} {
      // Allow authenticated users to upload
      allow write: if request.auth != null && request.resource.size < 100 * 1024 * 1024;
      // Allow public read for uploaded files
      allow read: if true;
    }
  }
}
