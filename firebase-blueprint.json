{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "role": { "type": "string", "description": "Role in the project" },
        "client": { "type": "string", "description": "Client name" },
        "year": { "type": "string", "description": "Project year" },
        "videoUrl": { "type": "string", "description": "External video URL (e.g. Youtube)" },
        "videoFile": { "type": "string", "description": "Uploaded video file path" },
        "thumbnailUrl": { "type": "string", "description": "Thumbnail image URL" },
        "description": { "type": "string", "description": "Project description (HTML)" },
        "isFeatured": { "type": "boolean", "description": "Whether the project is featured" },
        "category": { "type": "string", "description": "Project category" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["title", "category"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global site configuration",
      "type": "object",
      "properties": {
        "logoText": { "type": "string" },
        "logoImage": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" },
        "heroVideo": { "type": "string" },
        "aboutTitle": { "type": "string" },
        "aboutDescription": { "type": "string" },
        "aboutProfileImage": { "type": "string" },
        "aboutDescFontSize": { "type": "string" },
        "aboutDescFontWeight": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactInstagram": { "type": "string" },
        "contactX": { "type": "string" },
        "contactYoutube": { "type": "string" },
        "clients": { "type": "string", "description": "Comma separated list of client names or image URLs" }
      }
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/settings/site": {
      "schema": "SiteSettings",
      "description": "Global site settings document"
    }
  }
}
